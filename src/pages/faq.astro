---
import Layout from '../layouts/Layout.astro';
import { BRAND, FAQ } from '../data/siteData';

const title = '常見問題 | JST 頭皮護理';
const desc = 'JST 頭皮護理常見問題：預約方式、療程流程、效果說明、產品使用等，為您解答所有疑問。';
---

<Layout title={title} description={desc}>
  <div class="bg-gradient-to-br from-ivory to-cream pt-32 pb-16 text-center border-b border-sage-light">
    <div class="container-main">
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">常見問題</h1>
      <p class="text-lg text-text-secondary max-w-xl mx-auto">找不到答案？歡迎直接聯絡我們，專人為您解答</p>
    </div>
  </div>

  <section class="py-20 bg-cream">
    <div class="container-main max-w-4xl">
      {FAQ.map((cat, ci) => (
        <div class="mb-12 animate-on-scroll" style={`transition-delay:${ci*0.1}s`}>
          <h2 class="text-xl font-bold text-sage-dark inline-block border-b-2 border-sage-light pb-2 mb-6">
            {cat.category}
          </h2>
          <div class="space-y-3">
            {cat.items.map((item, ii) => (
              <div class="faq-item bg-white rounded-card shadow-sm overflow-hidden">
                <button class="faq-question w-full flex justify-between items-center p-5 md:p-6 text-left font-medium text-text-primary hover:bg-cream/50 transition-colors" data-cat={ci} data-idx={ii}>
                  <span class="pr-4">{item.q}</span>
                  <svg class="faq-icon w-4 h-4 text-sage transition-transform duration-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="faq-answer">
                  <div class="px-5 md:px-6 pb-5 text-text-secondary text-sm md:text-base leading-relaxed">{item.a}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <script>
    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const wasActive = item.classList.contains('active');
        document.querySelectorAll('.faq-item.active').forEach(el => el.classList.remove('active'));
        if (!wasActive) item.classList.add('active');
      });
    });
  </script>

  <!-- CTA -->
  <section class="py-20 text-center bg-gradient-to-br from-sage-light to-ivory">
    <div class="container-main animate-on-scroll">
      <h2 class="text-3xl font-bold text-text-primary mb-4">還有其他問題？</h2>
      <p class="text-text-secondary mb-8">我們樂意為您解答，歡迎隨時聯絡</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/jst-scalp-care/contact/" class="inline-flex items-center bg-sage text-white rounded-pill px-8 py-3.5 font-medium hover:bg-sage-dark hover:-translate-y-0.5 transition-all shadow-cta">
          聯絡我們
        </a>
        <a href={BRAND.social.line} target="_blank" class="inline-flex items-center bg-line text-white rounded-pill px-8 py-3.5 font-medium hover:bg-line-dark hover:-translate-y-0.5 transition-all shadow-md">
          LINE 諮詢
        </a>
      </div>
    </div>
  </section>
</Layout>
