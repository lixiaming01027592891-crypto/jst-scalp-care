---
import Layout from '../layouts/Layout.astro';

const title = '404 - 找不到頁面 | JSt.*頭皮養護中心';
const desc = '您要找的頁面不存在。回到 JSt.*頭皮養護中心 Scalp Care Art Center 首頁，探索我們的專業頭皮養護服務。';
---

<Layout title={title} description={desc}>
  <section class="min-h-[70vh] flex items-center justify-center bg-cream pt-32 pb-16">
    <div class="text-center px-6 max-w-lg mx-auto animate-on-scroll">
      <div class="text-8xl font-bold text-sage-light mb-4">404</div>
      <h1 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">找不到這個頁面</h1>
      <p class="text-text-secondary mb-8 leading-relaxed">
        您要找的頁面可能已被移除、名稱已更改，或暫時無法使用。
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="inline-flex items-center justify-center bg-sage text-white rounded-pill px-8 py-3 font-medium hover:bg-sage-dark transition-all">
          回到首頁
        </a>
        <a href="/contact/" class="inline-flex items-center justify-center border-[1.5px] border-sage text-sage rounded-pill px-8 py-3 font-medium hover:bg-sage hover:text-white transition-all">
          預約諮詢
        </a>
      </div>
    </div>
  </section>
</Layout>
