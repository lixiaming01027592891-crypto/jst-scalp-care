---
const title = 'JSt.*頭皮養護中心 | 官方連結';
const desc = 'JSt.*頭皮養護中心 Scalp Care Art Center 官方連結頁面 - 官網、LINE預約、Facebook、Instagram、蝦皮拍賣、電話聯絡';

const links = [
  { label: '官方網站', url: 'https://jst-scalp-care.pages.dev', icon: 'globe', color: 'bg-sage hover:bg-sage-dark' },
  { label: 'LINE 預約諮詢', url: 'https://lin.ee/your-line-id', icon: 'line', color: 'bg-[#06C755] hover:bg-[#04a348]' },
  { label: 'Facebook 粉絲專頁', url: 'https://www.facebook.com/share/14iCfkqjqtS/?mibextid=wwXIfr', icon: 'facebook', color: 'bg-[#1877F2] hover:bg-[#1464c0]' },
  { label: 'Instagram (@jst_coming)', url: 'https://www.instagram.com/jst_coming', icon: 'instagram', color: 'bg-gradient-to-r from-[#f58529] via-[#dd2a7b] to-[#8134af]' },
  { label: 'Instagram (@luminousjasmine)', url: 'https://www.instagram.com/luminousjasmine?igsh=MTllMDJjdzNrbnRibA%3D%3D&utm_source=qr', icon: 'instagram', color: 'bg-gradient-to-r from-[#f58529] via-[#dd2a7b] to-[#8134af]' },
  { label: '雅筑芳療精油', url: 'https://www.easecoxgroup.com/Product/List.aspx?cid=4&sid=5', icon: 'oil', color: 'bg-amber-600 hover:bg-amber-700' },
  { label: '蝦皮拍賣賣場', url: 'https://shopee.tw/jstscalpcare', icon: 'shop', color: 'bg-[#EE4D2D] hover:bg-[#d03515]' },
  { label: '電話預約', url: 'tel:03528XXXX', icon: 'phone', color: 'bg-sage hover:bg-sage-dark' },
];
---

<!doctype html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={desc} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={desc} />
  <meta property="og:image" content="https://jst-scalp-care.pages.dev/images/hero-bg.jpg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Noto Sans TC', 'PingFang TC', 'Microsoft JhengHei', sans-serif;
      background: #FAF8F5;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 40px 20px;
    }
    .logo-circle {
      width: 100px; height: 100px; border-radius: 50%;
      background: #A8B5A0;
      display: flex; align-items: center; justify-content: center;
      color: white; font-size: 28px; font-weight: 700;
      margin-bottom: 16px; box-shadow: 0 4px 16px rgba(168,181,160,0.3);
    }
    .brand-name { font-size: 20px; font-weight: 700; color: #3D3D3D; letter-spacing: 0.05em; margin-bottom: 4px; }
    .brand-sub { font-size: 14px; color: #9A9A9A; margin-bottom: 32px; }
    .links-container { width: 100%; max-width: 480px; display: flex; flex-direction: column; gap: 12px; }
    .link-btn {
      display: flex; align-items: center; gap: 12px;
      padding: 16px 20px; border-radius: 12px;
      color: white; text-decoration: none; font-weight: 500;
      transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .link-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }
    .link-btn svg { width: 22px; height: 22px; flex-shrink: 0; }
    .link-btn span { flex: 1; text-align: center; }
    .arrow { opacity: 0.6; font-size: 18px; }
    .footer { margin-top: 40px; font-size: 12px; color: #9A9A9A; text-align: center; }
    .promo-banner {
      width: 100%; max-width: 480px; margin: 24px 0;
      background: linear-gradient(135deg, #E8DCC8, #F0E6C8);
      border: 2px solid #D4AF37; border-radius: 16px;
      padding: 16px 20px; text-align: center; cursor: pointer;
      transition: all 0.3s ease;
    }
    .promo-banner:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(212,175,55,0.2); }
    .promo-banner h3 { font-size: 16px; color: #3D3D3D; margin-bottom: 4px; }
    .promo-banner p { font-size: 13px; color: #8A9A82; }
  </style>
</head>
<body>
  <div class="logo-circle">JSt.</div>
  <div class="brand-name">JSt.*頭皮養護中心</div>
  <div class="brand-sub">Scalp Care Art Center | 新竹</div>

  <a href="/mothers-day/" class="promo-banner">
    <h3>🌷 母親節限定活動進行中</h3>
    <p>3堂課程9折 · 送頭皮光療活氧 →</p>
  </a>

  <div class="links-container">
    {links.map(link => (
      <a href={link.url} class={`link-btn ${link.color}`} target="_blank" rel="noopener noreferrer">
        {link.icon === 'globe' && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10A15.3 15.3 0 0112 2z"/></svg>}
        {link.icon === 'line' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21.96 11.28c0-4.34-4.33-7.86-9.66-7.86S2.64 6.94 2.64 11.28c0 3.89 3.45 7.15 8.12 7.76.32.07.74.2.85.47.1.24.06.58.03.81l-.14.85c-.04.24-.19.94.82.51.99-.42 5.35-3.14 7.3-5.38.98-1.12 1.34-2.25 1.34-3.02zm-13.2-1.57h-.74c-.1 0-.18.08-.18.18v4.08c0 .1.08.18.18.18h.74c.1 0 .18-.08.18-.18V9.89c0-.1-.08-.18-.18-.18zm5.54 0h-.74c-.1 0-.18.08-.18.18v2.41l-1.8-2.47c-.04-.05-.1-.08-.16-.08h-.74c-.1 0-.18.08-.18.18v4.08c0 .1.08.18.18.18h.74c.1 0 .18-.08.18-.18v-2.41l1.8 2.47c.04.05.1.08.16.08h.74c.1 0 .18-.08.18-.18V9.89c0-.1-.08-.18-.18-.18zm-3.13 0h-2.6c-.1 0-.18.08-.18.18v.52c0 .1.08.18.18.18h.84v3.38c0 .1.08.18.18.18h.74c.1 0 .18-.08.18-.18v-3.38h.84c.1 0 .18-.08.18-.18v-.52c0-.1-.08-.18-.18-.18zm7.26 0h-2.6c-.1 0-.18.08-.18.18v.52c0 .1.08.18.18.18h.84v3.38c0 .1.08.18.18.18h.74c.1 0 .18-.08.18-.18v-3.38h.84c.1 0 .18-.08.18-.18v-.52c0-.1-.08-.18-.18-.18z"/></svg>}
        {link.icon === 'facebook' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>}
        {link.icon === 'instagram' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>}
        {link.icon === 'shop' && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>}
        {link.icon === 'phone' && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>}
        {link.icon === 'oil' && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0L12 2.69zM12 22a6 6 0 004.24-10.24L12 7.51l-4.24 4.24A6 6 0 0012 22z"/><path d="M12 11v6m-3-3h6"/></svg>}
        <span>{link.label}</span>
        <span class="arrow">→</span>
      </a>
    ))}
  </div>

  <div class="footer">
    © 2025 JSt.*頭皮養護中心 Scalp Care Art Center<br />
    新竹市東區光復路一段 XXX 號
  </div>
</body>
</html>
