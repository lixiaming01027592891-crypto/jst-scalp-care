---
import Layout from '../layouts/Layout.astro';
import FloatingContact from '../components/FloatingContact.astro';
import { BRAND } from '../data/siteData';

const title = '母親節限定活動 | JSt.*頭皮養護中心';
const desc = 'JSt.*頭皮養護中心 Scalp Care Art Center 母親節限定！能量精油頭刮Spa+客製化肩頸循環按摩+淨化毛囊，3堂課程9折再送頭皮光療活氧。活動期間2025/5/1-6/15。';

const courseItems = [
  '能量精油頭刮Spa (頭部經絡舒壓)',
  '客製化肩頸循環按摩',
  '淨化毛囊深層護理',
  '頭皮光療活氧 (贈送)',
];

const whyItems = [
  { num: '01', title: '科學分析頭皮狀態', desc: '60倍放大鏡專業儀器，精準掌握頭皮健康' },
  { num: '02', title: '一站式客製化服務', desc: '依個人狀態調理，非制式化療程' },
  { num: '03', title: '放鬆的環境氛圍', desc: '沙龍級舒適空間，完全放鬆身心' },
  { num: '04', title: '不推銷、無壓力', desc: '專注療程本身，讓您安心享受' },
];
---

<Layout title={title} description={desc} ogImage="images/hero-bg.jpg">
  <!-- Hero Banner -->
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
    <img src="/images/hero-bg.jpg" alt="JSt. 頭皮養護中心母親節活動" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-b from-cream/40 via-cream/60 to-cream"></div>
    <div class="relative z-10 text-center px-6 pt-24 pb-16 max-w-2xl mx-auto">
      <span class="inline-block bg-gold text-white text-sm font-bold px-4 py-1.5 rounded-full mb-6 tracking-wider">LIMITED TIME OFFER</span>
      <h1 class="text-3xl md:text-5xl font-bold text-text-primary mb-4 leading-tight">
        母親節限定活動
      </h1>
      <p class="text-lg text-text-secondary mb-2">能量精油頭刮Spa</p>
      <p class="text-base text-text-secondary mb-8">客製化肩頸循環按摩 + 淨化毛囊</p>
      <div class="inline-flex items-center gap-3 bg-white/80 backdrop-blur rounded-full px-6 py-3 shadow-md mb-8">
        <span class="text-sm text-text-secondary">活動期間</span>
        <span class="text-sm font-bold text-sage-dark">2025/5/1 - 6/15</span>
      </div>
    </div>
  </section>

  <!-- Price Section -->
  <section class="py-16 bg-ivory">
    <div class="container-main max-w-2xl">
      <div class="bg-white rounded-pricing shadow-card p-8 md:p-10 text-center border-2 border-gold relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gold-light via-gold to-gold-light"></div>
        <span class="inline-block bg-gold text-white text-xs font-bold px-3 py-1 rounded-full mb-4">3堂課程9折</span>
        <div class="text-5xl font-bold text-sage-dark mb-2">
          NT$<span class="text-6xl">1,500</span>
        </div>
        <p class="text-sm text-text-light mb-6">原價 NT$2,130 / 單堂優惠價</p>
        <div class="bg-cream rounded-card p-5 mb-6 text-left">
          <p class="text-sm font-bold text-text-primary mb-3">課程內容包含：</p>
          <ul class="space-y-2">
            {courseItems.map(item => (
              <li class="flex items-center gap-2 text-sm text-text-secondary">
                <svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-gold-light/30 rounded-card p-4 mb-8">
          <p class="text-sm font-bold text-text-primary">
            🎁 加贈：頭皮光療活氧 1次（價值NT$800）
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href={BRAND.social.line} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-line text-white rounded-pill px-8 py-3.5 font-medium hover:bg-line-dark hover:-translate-y-0.5 transition-all shadow-md">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M21.96 11.28c0-4.34-4.33-7.86-9.66-7.86S2.64 6.94 2.64 11.28c0 3.89 3.45 7.15 8.12 7.76.32.07.74.2.85.47.1.24.06.58.03.81l-.14.85c-.04.24-.19.94.82.51.99-.42 5.35-3.14 7.3-5.38.98-1.12 1.34-2.25 1.34-3.02z"/></svg>
            LINE 立即預約
          </a>
          <a href={`tel:${BRAND.phoneClean}`} class="inline-flex items-center justify-center gap-2 border-[1.5px] border-sage text-sage rounded-pill px-8 py-3.5 font-medium hover:bg-sage hover:text-white transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {BRAND.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose -->
  <section class="py-20 bg-cream">
    <div class="container-main">
      <h2 class="text-3xl font-bold text-text-primary text-center mb-12">為什麼選擇 JSt.* 頭皮養護？</h2>
      <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {whyItems.map(item => (
          <div class="bg-white rounded-card p-6 shadow-card flex items-start gap-4">
            <span class="text-3xl font-bold text-sage-light flex-shrink-0">{item.num}</span>
            <div>
              <h3 class="font-bold text-text-primary mb-1">{item.title}</h3>
              <p class="text-sm text-text-secondary">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Back to Links -->
  <section class="py-16 bg-ivory text-center">
    <div class="container-main">
      <p class="text-text-secondary mb-4">想查看所有官方連結？</p>
      <a href="/links/" class="inline-flex items-center gap-2 bg-sage text-white rounded-pill px-6 py-3 font-medium hover:bg-sage-dark transition-all">
        ← 回到官方連結頁
      </a>
    </div>
  </section>

  <FloatingContact />
</Layout>
