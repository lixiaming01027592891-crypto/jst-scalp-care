---
import Layout from '../layouts/Layout.astro';
import { BRAND } from '../data/siteData';
import { BLOG_POSTS } from '../data/blogPosts';

const title = '頭皮養護知識｜新竹頭皮保養與頭皮護理文章｜JSt.*頭皮養護中心';
const desc = '新竹頭皮保養與頭皮護理知識文章，涵蓋頭皮SPA、頭皮檢測、日常養護、出油改善、頭皮屑處理等實用內容。了解頭皮健康知識，找到適合自己的保養方式。';

const categoryColors: Record<string, string> = {
  '保養知識': 'bg-sage-light text-sage-dark',
  '問題改善': 'bg-gold-light text-gold-dark',
  '服務介紹': 'bg-wood-light text-wood-dark',
};
---

<Layout title={title} description={desc} ogImage="/images/scalp-illust.jpg">
  <!-- Page Header -->
  <div class="bg-gradient-to-br from-ivory to-cream pt-32 pb-16 text-center border-b border-sage-light">
    <div class="container-main">
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-4">頭皮養護知識</h1>
      <p class="text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">
        從日常保養到專業護理，給你實用的<span class="text-sage font-medium">新竹頭皮保養</span>與<span class="text-sage font-medium">新竹頭皮護理</span>知識。<br class="hidden md:block" />
        了解頭皮健康，找到適合自己的<span class="text-sage font-medium">新竹頭皮養護</span>方式。
      </p>
    </div>
  </div>

  <!-- Category Filter -->
  <section class="py-8 bg-cream border-b border-sage-light">
    <div class="container-main">
      <div class="flex flex-wrap gap-3 justify-center" id="categoryFilter">
        <button data-cat="all" class="filter-btn active text-sm font-medium px-5 py-2 rounded-pill transition-all bg-sage text-white">
          全部文章
        </button>
        <button data-cat="保養知識" class="filter-btn text-sm font-medium px-5 py-2 rounded-pill transition-all bg-white text-text-secondary border border-sage-light hover:border-sage hover:text-sage">
          保養知識
        </button>
        <button data-cat="問題改善" class="filter-btn text-sm font-medium px-5 py-2 rounded-pill transition-all bg-white text-text-secondary border border-sage-light hover:border-sage hover:text-sage">
          問題改善
        </button>
        <button data-cat="服務介紹" class="filter-btn text-sm font-medium px-5 py-2 rounded-pill transition-all bg-white text-text-secondary border border-sage-light hover:border-sage hover:text-sage">
          服務介紹
        </button>
      </div>
    </div>
  </section>

  <!-- Blog Post Grid -->
  <section class="py-20 bg-cream">
    <div class="container-main">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="blogGrid">
        {BLOG_POSTS.map((post, i) => (
          <article
            class="blog-card group bg-white rounded-card shadow-card hover:shadow-card-hover hover:-translate-y-1 transition-all duration-300 animate-on-scroll"
            data-category={post.category}
            style={`transition-delay:${(i % 3) * 0.1}s`}
          >
            <!-- Card Image Placeholder -->
            <div class="rounded-card overflow-hidden aspect-[16/10] m-4 mb-0 bg-gradient-to-br from-sage-light to-ivory flex items-center justify-center">
              <svg class="w-12 h-12 text-sage/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>

            <div class="p-5">
              <!-- Meta -->
              <div class="flex items-center gap-2 mb-3">
                <span class={`text-xs font-medium px-3 py-1 rounded-full ${categoryColors[post.category] || 'bg-sage-light text-sage-dark'}`}>
                  {post.category}
                </span>
                <span class="text-xs text-text-light">{post.readTime}</span>
              </div>

              <!-- Title -->
              <h2 class="text-lg font-bold text-text-primary mb-2 leading-snug group-hover:text-sage transition-colors line-clamp-2">
                <a href={`/blog/${post.slug}/`} class="focus:outline-none">
                  <span class="absolute inset-0" aria-hidden="true"></span>
                  {post.title}
                </a>
              </h2>

              <!-- Description -->
              <p class="text-sm text-text-secondary leading-relaxed mb-4 line-clamp-3">
                {post.description}
              </p>

              <!-- Date -->
              <div class="flex items-center gap-1.5 text-xs text-text-light pt-3 border-t border-sage-light">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                <time datetime={post.date}>{post.date.replace(/-/g, '.')}</time>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty State (hidden by default) -->
      <div id="emptyState" class="hidden text-center py-20">
        <p class="text-text-secondary">此分類暫無文章</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 text-center bg-gradient-to-br from-sage-light to-ivory">
    <div class="container-main animate-on-scroll">
      <h2 class="text-3xl font-bold text-text-primary mb-4">想更了解自己的頭皮？</h2>
      <p class="text-text-secondary max-w-md mx-auto mb-8">
        每個人的頭皮狀態都不同，讓我們從專業檢測開始，找到適合你的保養方式。
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/services/" class="inline-flex items-center bg-sage text-white rounded-pill px-8 py-3.5 font-medium hover:bg-sage-dark hover:-translate-y-0.5 transition-all shadow-cta">
          了解服務項目
        </a>
        <a href="/contact/" class="inline-flex items-center border-[1.5px] border-sage text-sage rounded-pill px-8 py-3.5 font-medium hover:bg-sage hover:text-white hover:-translate-y-0.5 transition-all">
          預約諮詢
        </a>
      </div>
    </div>
  </section>

  <script>
    // Category filter
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.blog-card');
    const emptyState = document.getElementById('emptyState');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.cat;

        // Update button styles
        filterBtns.forEach(b => {
          b.classList.remove('bg-sage', 'text-white');
          b.classList.add('bg-white', 'text-text-secondary', 'border', 'border-sage-light');
        });
        btn.classList.remove('bg-white', 'text-text-secondary', 'border', 'border-sage-light');
        btn.classList.add('bg-sage', 'text-white');

        // Filter cards
        let visible = 0;
        cards.forEach(card => {
          const match = cat === 'all' || card.dataset.category === cat;
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });

        emptyState.style.display = visible === 0 ? 'block' : 'none';
      });
    });
  </script>

  <style>
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .line-clamp-3 {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .blog-card {
      position: relative;
    }
  </style>
</Layout>
