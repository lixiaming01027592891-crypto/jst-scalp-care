---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { BRAND } from '../../data/siteData';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'blog'> };
const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, date, category, readTime, keywords, image } = entry.data;

const categoryColors: Record<string, string> = {
  '保養知識': 'bg-sage-light text-sage-dark',
  '問題改善': 'bg-gold-light text-gold-dark',
  '服務介紹': 'bg-wood-light text-wood-dark',
};

const allPosts = await getCollection('blog');
function getRelatedPosts(currentSlug: string, category: string) {
  const others = allPosts.filter(p => p.slug !== currentSlug);
  // 同分類優先，不足 3 篇再用其他分類補滿
  const sameCategory = others.filter(p => p.data.category === category);
  const rest = others.filter(p => p.data.category !== category);
  return [...sameCategory, ...rest].slice(0, 3);
}

const related = getRelatedPosts(entry.slug, category);

const articleUrl = new URL(`/blog/${entry.slug}/`, BRAND.url).toString();
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": new URL(image, BRAND.url).toString(),
  "datePublished": date,
  "dateModified": date,
  "keywords": keywords.join(', '),
  "articleSection": category,
  "inLanguage": "zh-TW",
  "mainEntityOfPage": { "@type": "WebPage", "@id": articleUrl },
  "author": { "@type": "Organization", "name": BRAND.name, "url": BRAND.url },
  "publisher": { "@type": "Organization", "name": BRAND.name, "url": BRAND.url },
};
---

<Layout title={title} description={description} ogImage={image}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} is:inline />
  <!-- Article Header -->
  <div class="bg-gradient-to-br from-ivory to-cream pt-32 pb-12 border-b border-sage-light">
    <div class="container-main max-w-3xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <span class={`text-xs font-medium px-3 py-1 rounded-full ${categoryColors[category] || 'bg-sage-light text-sage-dark'}`}>
          {category}
        </span>
        <span class="text-xs text-text-light">{readTime}</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-text-primary mb-4 leading-tight">
        {title}
      </h1>
      <p class="text-text-secondary leading-relaxed mb-6">
        {description}
      </p>
      <div class="flex items-center gap-4 text-sm text-text-light">
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <time datetime={date}>{date.replace(/-/g, '.')}</time>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
          </svg>
          {keywords.slice(0, 3).join('、')}
        </div>
      </div>
    </div>
  </div>

  <!-- Hero Image -->
  <div class="container-main max-w-3xl mx-auto px-6 -mt-0">
    <div class="rounded-card overflow-hidden shadow-card my-8">
      <img src={image} alt={title} class="w-full aspect-[16/9] object-cover" loading="eager" />
    </div>
  </div>

  <!-- Article Content -->
  <article class="container-main max-w-3xl mx-auto px-6 pb-20">
    <div class="blog-content text-text-primary leading-[1.85] text-[1.05rem]">
      <Content />
    </div>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mt-12 pt-8 border-t border-sage-light">
      {keywords.map(kw => (
        <span class="text-xs font-medium px-3 py-1.5 rounded-full bg-ivory text-text-secondary border border-sage-light">
          {kw}
        </span>
      ))}
    </div>
  </article>

  <!-- Related Posts -->
  {related.length > 0 && (
    <section class="py-16 bg-ivory border-t border-sage-light">
      <div class="container-main max-w-3xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-text-primary mb-8">更多頭皮養護文章</h2>
        <div class="flex flex-col gap-4">
          {related.map(r => (
            <a href={`/blog/${r.slug}/`} class="group flex gap-4 bg-white rounded-card p-4 shadow-card hover:shadow-card-hover transition-all">
              <div class="w-24 h-24 flex-shrink-0 rounded-lg overflow-hidden bg-sage-light">
                <img src={r.data.image} alt={r.data.title} class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class={`text-[10px] font-medium px-2 py-0.5 rounded-full ${categoryColors[r.data.category] || ''}`}>{r.data.category}</span>
                  <span class="text-[10px] text-text-light">{r.data.readTime}</span>
                </div>
                <h3 class="text-sm font-bold text-text-primary group-hover:text-sage transition-colors line-clamp-2 leading-snug">
                  {r.data.title}
                </h3>
                <p class="text-xs text-text-secondary mt-1 line-clamp-1">{r.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-20 text-center bg-gradient-to-br from-sage-light to-ivory">
    <div class="container-main animate-on-scroll">
      <h2 class="text-3xl font-bold text-text-primary mb-4">想親自體驗？</h2>
      <p class="text-text-secondary max-w-md mx-auto mb-8">
        每個人的頭皮狀態都不同，從專業檢測開始，找到適合自己的保養方式。
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/services/" class="inline-flex items-center bg-sage text-white rounded-pill px-8 py-3.5 font-medium hover:bg-sage-dark hover:-translate-y-0.5 transition-all shadow-cta">
          了解服務項目
        </a>
        <a href="/contact/" class="inline-flex items-center border-[1.5px] border-sage text-sage rounded-pill px-8 py-3.5 font-medium hover:bg-sage hover:text-white hover:-translate-y-0.5 transition-all">
          預約諮詢
        </a>
      </div>
    </div>
  </section>

  <style>
    .blog-content h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #3D3D3D;
      margin-top: 2.5rem;
      margin-bottom: 1.25rem;
      line-height: 1.4;
    }
    .blog-content p {
      margin-bottom: 1.5rem;
      color: #4a4a4a;
    }
    .blog-content img {
      width: 100%;
      border-radius: 16px;
      margin: 2rem 0;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    .blog-content p + p {
      margin-top: -0.5rem;
    }
    .line-clamp-1 {
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</Layout>
