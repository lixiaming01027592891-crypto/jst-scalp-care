---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  currentPage: number;
  totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props;

const categoryColors: Record<string, string> = {
  '保養知識': 'bg-sage-light text-sage-dark',
  '問題改善': 'bg-gold-light text-gold-dark',
  '服務介紹': 'bg-wood-light text-wood-dark',
};

function pageUrl(page: number) {
  return page === 1 ? '/blog/' : `/blog/page/${page}/`;
}

const pageNumbers = Array.from({ length: totalPages }, (_, idx) => idx + 1);
---
<section class="py-8 bg-cream border-b border-sage-light">
  <div class="container-main">
    <div class="flex flex-wrap gap-3 justify-center" id="categoryFilter">
      <button type="button" data-cat="all" aria-pressed="true" class="filter-btn active text-sm font-medium px-5 py-2 rounded-pill transition-all bg-sage text-white">
        全部文章
      </button>
      <button type="button" data-cat="保養知識" aria-pressed="false" class="filter-btn text-sm font-medium px-5 py-2 rounded-pill transition-all bg-white text-text-secondary border border-sage-light hover:border-sage hover:text-sage">
        保養知識
      </button>
      <button type="button" data-cat="問題改善" aria-pressed="false" class="filter-btn text-sm font-medium px-5 py-2 rounded-pill transition-all bg-white text-text-secondary border border-sage-light hover:border-sage hover:text-sage">
        問題改善
      </button>
      <button type="button" data-cat="服務介紹" aria-pressed="false" class="filter-btn text-sm font-medium px-5 py-2 rounded-pill transition-all bg-white text-text-secondary border border-sage-light hover:border-sage hover:text-sage">
        服務介紹
      </button>
    </div>
  </div>
</section>

<section class="py-20 bg-cream">
  <div class="container-main">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="blogGrid">
      {posts.map((entry, i) => (
        <article
          class="blog-card group bg-white rounded-card shadow-card hover:shadow-card-hover hover:-translate-y-1 transition-all duration-300 animate-on-scroll overflow-hidden"
          data-category={entry.data.category}
          style={`transition-delay:${(i % 3) * 0.1}s`}
        >
          <div class="rounded-card overflow-hidden aspect-[16/10] m-4 mb-0 bg-sage-light">
            <img
              src={entry.data.image}
              alt={entry.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="p-5">
            <div class="flex items-center gap-2 mb-3">
              <span class={`text-xs font-medium px-3 py-1 rounded-full ${categoryColors[entry.data.category] || 'bg-sage-light text-sage-dark'}`}>
                {entry.data.category}
              </span>
              <span class="text-xs text-text-light">{entry.data.readTime}</span>
            </div>

            <h2 class="text-lg font-bold text-text-primary mb-2 leading-snug group-hover:text-sage transition-colors line-clamp-2">
              <a href={`/blog/${entry.slug}/`} class="focus:outline-none">
                <span class="absolute inset-0" aria-hidden="true"></span>
                {entry.data.title}
              </a>
            </h2>

            <p class="text-sm text-text-secondary leading-relaxed mb-4 line-clamp-3">
              {entry.data.description}
            </p>

            <div class="flex items-center gap-1.5 text-xs text-text-light pt-3 border-t border-sage-light">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <time datetime={entry.data.date}>{entry.data.date.replace(/-/g, '.')}</time>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div id="emptyState" class="text-center py-20" hidden>
      <p class="text-text-secondary">此分類暫無文章</p>
    </div>

    {totalPages > 1 && (
      <nav class="flex flex-wrap justify-center items-center gap-2 mt-12" aria-label="文章分頁">
        {currentPage > 1 ? (
          <a href={pageUrl(currentPage - 1)} rel="prev" class="inline-flex items-center px-4 py-2 rounded-pill bg-white border border-sage-light text-sm font-medium text-text-secondary hover:border-sage hover:text-sage transition-colors">
            上一頁
          </a>
        ) : (
          <span class="inline-flex items-center px-4 py-2 rounded-pill bg-ivory border border-sage-light text-sm font-medium text-text-light cursor-not-allowed" aria-disabled="true">
            上一頁
          </span>
        )}

        {pageNumbers.map(p => (
          p === currentPage ? (
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-sage text-white text-sm font-medium" aria-current="page">{p}</span>
          ) : (
            <a href={pageUrl(p)} class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white border border-sage-light text-sm font-medium text-text-secondary hover:border-sage hover:text-sage transition-colors">{p}</a>
          )
        ))}

        {currentPage < totalPages ? (
          <a href={pageUrl(currentPage + 1)} rel="next" class="inline-flex items-center px-4 py-2 rounded-pill bg-white border border-sage-light text-sm font-medium text-text-secondary hover:border-sage hover:text-sage transition-colors">
            下一頁
          </a>
        ) : (
          <span class="inline-flex items-center px-4 py-2 rounded-pill bg-ivory border border-sage-light text-sm font-medium text-text-light cursor-not-allowed" aria-disabled="true">
            下一頁
          </span>
        )}
      </nav>
    )}
  </div>
</section>

<script>
  var filterBtns = document.querySelectorAll('.filter-btn');
  var cards = document.querySelectorAll('.blog-card');
  var emptyState = document.getElementById('emptyState');

  filterBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var cat = btn.dataset.cat;

      filterBtns.forEach(function (b) {
        b.classList.remove('bg-sage', 'text-white');
        b.classList.add('bg-white', 'text-text-secondary', 'border', 'border-sage-light');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.remove('bg-white', 'text-text-secondary', 'border', 'border-sage-light');
      btn.classList.add('bg-sage', 'text-white');
      btn.setAttribute('aria-pressed', 'true');

      var visible = 0;
      cards.forEach(function (card) {
        var match = cat === 'all' || card.dataset.category === cat;
        card.hidden = !match;
        if (match) visible++;
      });

      if (emptyState) emptyState.hidden = visible !== 0;
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card {
    position: relative;
  }
</style>
