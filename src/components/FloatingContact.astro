---
import { BRAND } from '../data/siteData';
---

<!-- Desktop: Fixed right side contact buttons -->
<div class="fixed right-4 top-1/2 -translate-y-1/2 z-50 hidden lg:flex flex-col gap-3" id="sideButtons">
  <!-- LINE -->
  <a href={BRAND.social.line} target="_blank" rel="noopener noreferrer"
    class="group relative w-12 h-12 rounded-full bg-[#06C755] text-white flex items-center justify-center shadow-lg hover:scale-110 transition-all duration-300"
    aria-label="LINE 預約">
    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5-3.016c.348 0 .63.285.63.631 0 .345-.282.63-.63.63H9.804v1.125h1.706c.349 0 .631.283.631.63 0 .344-.282.629-.631.629H9.078c-.344 0-.626-.285-.626-.629V8.108c0-.345.282-.63.63-.63h2.432c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H9.804v1.125h1.706zm-4.703 2.1c.4.391.4 1.024 0 1.415-.2.195-.463.293-.725.293-.266 0-.528-.098-.728-.293l-1.436-1.405v.953c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v.954l1.436-1.406c.2-.195.462-.293.728-.293.262 0 .525.098.725.293.4.391.4 1.024 0 1.415l-1.367 1.338 1.367 1.338z"/></svg>
    <span class="absolute right-14 top-1/2 -translate-y-1/2 bg-[#06C755] text-white text-sm px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-md">LINE 預約</span>
  </a>

  <!-- Facebook -->
  <a href={BRAND.social.facebook} target="_blank" rel="noopener noreferrer"
    class="group relative w-12 h-12 rounded-full bg-[#1877F2] text-white flex items-center justify-center shadow-lg hover:scale-110 transition-all duration-300"
    aria-label="Facebook 粉專">
    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
    <span class="absolute right-14 top-1/2 -translate-y-1/2 bg-[#1877F2] text-white text-sm px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-md">Facebook</span>
  </a>

  <!-- Instagram -->
  <a href={BRAND.social.instagram} target="_blank" rel="noopener noreferrer"
    class="group relative w-12 h-12 rounded-full text-white flex items-center justify-center shadow-lg hover:scale-110 transition-all duration-300"
    style="background: linear-gradient(135deg, #f58529, #dd2a7b, #8134af);"
    aria-label="Instagram">
    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
    <span class="absolute right-14 top-1/2 -translate-y-1/2 text-white text-sm px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-md" style="background: linear-gradient(135deg, #f58529, #dd2a7b);">Instagram</span>
  </a>

  <!-- Phone -->
  <a href={`tel:${BRAND.phoneClean}`}
    class="group relative w-12 h-12 rounded-full bg-sage text-white flex items-center justify-center shadow-lg hover:scale-110 transition-all duration-300 hover:bg-sage-dark"
    aria-label="電話諮詢">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
    <span class="absolute right-14 top-1/2 -translate-y-1/2 bg-sage-dark text-white text-sm px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-md">{BRAND.phone}</span>
  </a>
</div>

<!-- Mobile: Bottom floating button -->
<div class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3 lg:hidden" id="floatWrapMobile">
  <div class="flex flex-col gap-3 items-end mb-2 opacity-0 pointer-events-none transition-all duration-300 translate-y-4" id="floatMenuMobile">
    <a href={BRAND.social.line} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-white rounded-full shadow-lg pr-5 pl-3 py-2.5 hover:shadow-xl transition-all">
      <span class="text-sm font-medium text-text-primary">LINE 預約</span>
      <div class="w-10 h-10 rounded-full bg-[#06C755] text-white flex items-center justify-center">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755z"/></svg>
      </div>
    </a>
    <a href={`tel:${BRAND.phoneClean}`} class="flex items-center gap-3 bg-white rounded-full shadow-lg pr-5 pl-3 py-2.5 hover:shadow-xl transition-all">
      <span class="text-sm font-medium text-text-primary">{BRAND.phone}</span>
      <div class="w-10 h-10 rounded-full bg-sage text-white flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      </div>
    </a>
  </div>
  <button id="floatToggleMobile" class="w-14 h-14 rounded-full shadow-lg flex items-center justify-center text-white bg-sage hover:bg-sage-dark transition-all duration-300 hover:shadow-xl hover:-translate-y-0.5"
    aria-label="聯絡方式">
    <svg id="floatIconOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
    <svg id="floatIconClose" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
</div>

<script>
  // Mobile floating button toggle
  const floatToggleMobile = document.getElementById('floatToggleMobile');
  const floatMenuMobile = document.getElementById('floatMenuMobile');
  const floatIconOpen = document.getElementById('floatIconOpen');
  const floatIconClose = document.getElementById('floatIconClose');
  let mobileOpen = false;

  if (floatToggleMobile && floatMenuMobile) {
    floatToggleMobile.addEventListener('click', () => {
      mobileOpen = !mobileOpen;
      floatMenuMobile.style.opacity = mobileOpen ? '1' : '0';
      floatMenuMobile.style.pointerEvents = mobileOpen ? 'auto' : 'none';
      floatMenuMobile.style.transform = mobileOpen ? 'translateY(0)' : 'translateY(16px)';
      floatIconOpen.classList.toggle('hidden', mobileOpen);
      floatIconClose.classList.toggle('hidden', !mobileOpen);
    });
  }
</script>
