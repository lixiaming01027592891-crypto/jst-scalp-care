---
import { BRAND, NAV_LINKS } from '../data/siteData';
const currentPath = Astro.url.pathname;
---

<style is:global>
  @keyframes jstMenuIn {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  #mobileMenu { display: none; }

  #mobileMenu.is-open {
    display: block !important;
    position: fixed !important;
    top: 72px !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    z-index: 60 !important;
    overflow-y: auto !important;
    background: rgba(255, 255, 255, 0.98) !important;
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    animation: jstMenuIn 0.28s cubic-bezier(.4, 0, .2, 1);
  }

  body.menu-open { overflow: hidden; touch-action: none; }

  html { scroll-padding-top: 80px; scroll-behavior: smooth; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
      scroll-behavior: auto !important;
    }
  }

  #navToggle:focus-visible,
  #mobileMenu a:focus-visible {
    outline: 2px solid #A8B5A0;
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>

<nav class="fixed top-0 left-0 right-0 h-[72px] bg-white/90 backdrop-blur-md z-50 shadow-[0_1px_0_rgba(0,0,0,0.05)] transition-shadow" id="navbar">
  <div class="container-main flex items-center justify-between h-full">
    <a href="/" class="text-xl font-bold tracking-wide text-text-primary">
      JSt.*<span class="text-sage">頭皮養護中心</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {NAV_LINKS.map(link => {
        const isActive = currentPath === link.path || currentPath === link.path.replace(/\/$/, '');
        return (
          <a
            href={link.path}
            class={`text-[0.9375rem] font-medium transition-colors relative after:absolute after:bottom-[-4px] after:left-0 after:h-[2px] after:bg-sage after:transition-all after:duration-300 ${isActive ? 'text-sage after:w-full' : 'text-text-primary hover:text-sage after:w-0 hover:after:w-full'}`}
          >
            {link.label}
          </a>
        );
      })}
    </div>

    <a href={BRAND.social.line} target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex items-center bg-line text-white rounded-pill px-5 py-2 text-sm font-medium hover:bg-line-dark transition-colors">
      LINE 預約
    </a>

    <button class="md:hidden flex flex-col gap-[5px] p-2" id="navToggle" aria-label="選單" aria-expanded="false" aria-controls="mobileMenu">
      <span class="block w-6 h-[2px] bg-text-primary transition-all" id="h1"></span>
      <span class="block w-6 h-[2px] bg-text-primary transition-all" id="h2"></span>
      <span class="block w-6 h-[2px] bg-text-primary transition-all" id="h3"></span>
    </button>
  </div>

  <div class="md:hidden" id="mobileMenu" role="dialog" aria-modal="true" aria-label="主選單" aria-hidden="true">
    <div class="container-main flex flex-col py-6 gap-1">
      {NAV_LINKS.map(link => {
        const isActive = currentPath === link.path || currentPath === link.path.replace(/\/$/, '');
        return (
          <a href={link.path} class={`py-3.5 text-lg font-medium border-b border-sage-light transition-colors ${isActive ? 'text-sage' : 'text-text-primary hover:text-sage'}`}>{link.label}</a>
        );
      })}
      <a href={BRAND.social.line} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center justify-center bg-line text-white rounded-pill px-5 py-3 text-base font-medium hover:bg-line-dark transition-colors">
        LINE 預約
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    function init() {
      var toggle = document.getElementById('navToggle');
      var menu = document.getElementById('mobileMenu');
      var h1 = document.getElementById('h1');
      var h2 = document.getElementById('h2');
      var h3 = document.getElementById('h3');
      var nav = document.getElementById('navbar');
      var body = document.body;
      if (!toggle || !menu) return;

      function isOpen() { return menu.classList.contains('is-open'); }

      var menuFallbackStyles = {
        display: 'block',
        position: 'fixed',
        top: '72px',
        left: '0',
        right: '0',
        bottom: '0',
        'z-index': '60',
        'overflow-y': 'auto',
        background: 'rgba(255, 255, 255, 0.98)',
        '-webkit-backdrop-filter': 'blur(16px)',
        'backdrop-filter': 'blur(16px)'
      };

      function setMenuFallbackStyles(open) {
        Object.keys(menuFallbackStyles).forEach(function (property) {
          if (open) {
            menu.style.setProperty(property, menuFallbackStyles[property], 'important');
          } else {
            menu.style.removeProperty(property);
          }
        });
      }

      function setMenu(open) {
        if (open) {
          menu.classList.add('is-open');
          body.classList.add('menu-open');
        } else {
          menu.classList.remove('is-open');
          body.classList.remove('menu-open');
        }
        setMenuFallbackStyles(open);
        menu.setAttribute('aria-hidden', open ? 'false' : 'true');
        if (h1) h1.style.transform = open ? 'rotate(45deg) translate(5px,5px)' : '';
        if (h2) h2.style.opacity = open ? '0' : '1';
        if (h3) h3.style.transform = open ? 'rotate(-45deg) translate(5px,-5px)' : '';
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      }

      toggle.addEventListener('click', function (e) {
        e.preventDefault();
        setMenu(!isOpen());
      });

      menu.addEventListener('click', function (e) {
        if (e.target === menu) setMenu(false);
      });

      menu.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () { setMenu(false); });
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && isOpen()) setMenu(false);
      });

      window.addEventListener('resize', function () {
        if (window.innerWidth >= 768 && isOpen()) setMenu(false);
      });

      if (nav) {
        window.addEventListener('scroll', function () {
          nav.style.boxShadow = window.scrollY > 50 ? '0 2px 12px rgba(0,0,0,0.08)' : '0 1px 0 rgba(0,0,0,0.05)';
        }, { passive: true });
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
