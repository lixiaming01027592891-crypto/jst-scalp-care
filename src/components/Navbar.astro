---
import { BRAND, NAV_LINKS } from '../data/siteData';
const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 h-[72px] bg-white/90 backdrop-blur-md z-50 shadow-[0_1px_0_rgba(0,0,0,0.05)] transition-shadow" id="navbar">
  <div class="container-main flex items-center justify-between h-full">
    <a href="/" class="text-xl font-bold tracking-wide text-text-primary">
      JSt.*<span class="text-sage">頭皮養護中心</span>
    </a>
    
    <!-- Desktop menu -->
    <div class="hidden md:flex items-center gap-8">
      {NAV_LINKS.map(link => {
        const isActive = currentPath === link.path || currentPath === link.path.replace(/\/$/, '');
        return (
          <a 
            href={link.path} 
            class={`text-[0.9375rem] font-medium transition-colors relative after:absolute after:bottom-[-4px] after:left-0 after:h-[2px] after:bg-sage after:transition-all after:duration-300 ${isActive ? 'text-sage after:w-full' : 'text-text-primary hover:text-sage after:w-0 hover:after:w-full'}`}
          >
            {link.label}
          </a>
        );
      })}
    </div>
    
    <!-- Desktop CTA -->
    <a href={BRAND.social.line} target="_blank" class="hidden md:inline-flex items-center bg-line text-white rounded-pill px-5 py-2 text-sm font-medium hover:bg-line-dark transition-colors">
      LINE 預約
    </a>
    
    <!-- Mobile hamburger -->
    <button class="md:hidden flex flex-col gap-[5px] p-2" id="navToggle" aria-label="選單">
      <span class="block w-6 h-[2px] bg-text-primary transition-all" id="h1"></span>
      <span class="block w-6 h-[2px] bg-text-primary transition-all" id="h2"></span>
      <span class="block w-6 h-[2px] bg-text-primary transition-all" id="h3"></span>
    </button>
  </div>
  
  <!-- Mobile menu overlay -->
  <div class="md:hidden fixed top-[72px] left-0 right-0 bottom-0 bg-white/98 backdrop-blur-lg z-[60] overflow-y-auto opacity-0 pointer-events-none transition-opacity duration-300" id="mobileMenu">
    <div class="container-main flex flex-col py-6 gap-1">
      {NAV_LINKS.map(link => {
        const isActive = currentPath === link.path || currentPath === link.path.replace(/\/$/, '');
        return (
          <a href={link.path} class={`py-3.5 text-lg font-medium border-b border-sage-light transition-colors ${isActive ? 'text-sage' : 'text-text-primary hover:text-sage'}`}>{link.label}</a>
        );
      })}
      <a href={BRAND.social.line} target="_blank" class="mt-4 inline-flex items-center justify-center bg-line text-white rounded-pill px-5 py-3 text-base font-medium hover:bg-line-dark transition-colors">
        LINE 預約
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    function init() {
      var toggle = document.getElementById('navToggle');
      var menu = document.getElementById('mobileMenu');
      var h1 = document.getElementById('h1');
      var h2 = document.getElementById('h2');
      var h3 = document.getElementById('h3');
      var nav = document.getElementById('navbar');
      if (!toggle || !menu) return;

      var open = false;
      function setMenu(o) {
        open = o;
        if (o) {
          menu.style.cssText = 'display:block !important;position:fixed;top:72px;left:0;right:0;bottom:0;background:rgba(255,255,255,0.98);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);z-index:60;overflow-y:auto;opacity:1;pointer-events:auto;transition:opacity 300ms;';
        } else {
          menu.style.cssText = 'display:none !important;';
        }
        if (h1) h1.style.transform = o ? 'rotate(45deg) translate(5px,5px)' : '';
        if (h2) h2.style.opacity = o ? '0' : '1';
        if (h3) h3.style.transform = o ? 'rotate(-45deg) translate(5px,-5px)' : '';
        toggle.setAttribute('aria-expanded', o ? 'true' : 'false');
      }

      toggle.addEventListener('click', function (e) { e.preventDefault(); setMenu(!open); });
      menu.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () { setMenu(false); });
      });

      if (nav) {
        window.addEventListener('scroll', function () {
          nav.style.boxShadow = window.scrollY > 50 ? '0 2px 12px rgba(0,0,0,0.08)' : '0 1px 0 rgba(0,0,0,0.05)';
        }, { passive: true });
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
